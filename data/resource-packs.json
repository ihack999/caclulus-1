  "weeklyPacks": {
    "Week 0": {"mission": "Repair pre-calculus weak spots before MIT starts.", "packKeys": ["precalc"], "checkpoints": ["Finish the readiness check", "Review every missed diagnostic topic", "Do 20 minutes of algebra/trig drills"]},
    "Week 1": {"mission": "Make limits and derivative meaning visual before memorizing rules.", "packKeys": ["limits", "derivatives"], "checkpoints": ["Explain derivative as slope in one sentence", "Do limit simplification drills", "Watch the first MIT clips before reading notes"]},
    "Week 2": {"mission": "Turn derivative rules into fast pattern recognition.", "packKeys": ["derivative-rules", "chain-rule"], "checkpoints": ["Name the rule before differentiating", "Drill trig derivatives", "Finish chain rule practice"]},
    "Week 3": {"mission": "Handle hidden variables and exponential/log derivatives, then test yourself.", "packKeys": ["implicit-exp-log", "chain-rule", "exam-prep"], "checkpoints": ["Differentiate implicit equations cleanly", "Practice log/exponential derivatives", "Attempt Exam 1 in Exam Mode"]},
    "Week 4": {"mission": "Use derivatives to understand approximation and graph behavior.", "packKeys": ["applications", "derivatives"], "checkpoints": ["Sketch with first/second derivative signs", "Practice linear approximation", "Tag graphing mistakes"]},
    "Week 5": {"mission": "Master word-problem setup for related rates and optimization.", "packKeys": ["related-rates-optimization", "applications"], "checkpoints": ["Draw every related-rates problem", "State optimization domains", "Redo the weakest setup type"]},
    "Week 6": {"mission": "Connect derivative theory, antiderivatives, and exam readiness.", "packKeys": ["applications", "antiderivatives", "exam-prep"], "checkpoints": ["Use MVT language correctly", "Practice antiderivative checks", "Attempt Exam 2 in Exam Mode"]},
    "Week 7": {"mission": "Build definite integral intuition from area and accumulation.", "packKeys": ["definite-integrals-ftc"], "checkpoints": ["Explain signed area", "Compute basic definite integrals", "Use FTC without mixing up bounds"]},
    "Week 8": {"mission": "Turn FTC and integral applications into geometry setup skills.", "packKeys": ["definite-integrals-ftc", "applications-integrals"], "checkpoints": ["Draw regions before integrating", "Choose washer/shell/slice method", "Check units of final answer"]},
    "Week 9": {"mission": "Practice mixed integral applications and then take Exam 3.", "packKeys": ["applications-integrals", "definite-integrals-ftc", "exam-prep"], "checkpoints": ["Do average value and probability examples", "Practice numerical integration", "Attempt Exam 3 in Exam Mode"]},
    "Week 10": {"mission": "Learn substitution and trig patterns as technique selection.", "packKeys": ["integration-techniques"], "checkpoints": ["Try u-sub first", "Memorize basic trig identities", "Check antiderivatives by differentiating"]},
